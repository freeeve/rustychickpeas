#!/bin/sh
# Pre-commit hook: the FAST half of CI's static gates (.github/workflows/ci.yml
# Lint job) — `cargo fmt --all --check`. The slower `clippy` gate runs in
# .githooks/pre-push (it compiles tests/benches/examples), so per-commit latency
# stays low while a CI-red push is still caught before it leaves your machine.
#
# Enable once per clone:
#     git config core.hooksPath .githooks
set -e

echo "pre-commit ▸ cargo fmt --all --check"
cargo fmt --all --check

echo "pre-commit ▸ ok (clippy runs in pre-push)"
